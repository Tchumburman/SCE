^.*\.Rproj$
^\.Rproj\.user$
^rsconnect$
^manifest\.json$
^\.rconnectignore$
^R_backup$
^nul$
^\.positai$
# Exclude Shiny module files from package R/ — they live in inst/app/R/
^R/00_topic_metadata\.R$
